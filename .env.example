# Gemini Vision API key from Google AI Studio (https://aistudio.google.com/apikey)
# Copy this file to `.env` and add your key before running analysis.
VITE_GEMINI_API_KEY=your_api_key_here

# Recommended model for free-tier Google AI Studio keys (as of 2026).
# gemini-2.0-flash may return quota errors (limit: 0) on newer keys.
VITE_GEMINI_MODEL=gemini-2.5-flash

# After changing .env, restart the dev server: npm run dev
